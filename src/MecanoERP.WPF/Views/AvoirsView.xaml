<UserControl x:Class="MecanoERP.WPF.Views.AvoirsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                <StackPanel Orientation="Horizontal">
                    <Border Width="4" Height="22" Background="#E9730C" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="Avoirs clients (Crédit notes)" Style="{StaticResource PageTitle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="➕ Nouvel avoir" Command="{Binding NouvelAvoirCommand}"
                            Style="{StaticResource PrimaryBtn}" Height="28" Margin="0,0,6,0"/>
                    <Button Content="🔄 Actualiser" Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Height="28" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding MessageStatut}" Foreground="#107E3E"
                               FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="2" Margin="14,10,14,0"
                      ItemsSource="{Binding Avoirs}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N° Avoir"     Binding="{Binding Numero}"            Width="130"/>
                    <DataGridTextColumn Header="Client"       Binding="{Binding Client.Nom}"         Width="160"/>
                    <DataGridTextColumn Header="Facture orig." Binding="{Binding FactureOrigine.Numero}" Width="130"/>
                    <DataGridTextColumn Header="Date"         Binding="{Binding DateAvoir, StringFormat=dd/MM/yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Montant"      Binding="{Binding Montant, StringFormat=C}"  Width="110"/>
                    <DataGridTextColumn Header="Motif"        Binding="{Binding Motif}"              Width="200"/>
                    <DataGridTextColumn Header="Statut"       Binding="{Binding Statut}"             Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="3"
                         Foreground="#E9730C" Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- Formulaire -->
        <Border Grid.Column="1" Width="300" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="1,0,0,0"
                Visibility="{Binding AfficherFormulaire, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#E9730C" Padding="16,12">
                    <TextBlock Text="Nouvel avoir client" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="14"/>
                </Border>
                <StackPanel Grid.Row="1" Margin="16,14,16,0">
                    <TextBlock Text="Client *" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Clients}" SelectedValuePath="Id"
                              SelectedValue="{Binding ClientId}" DisplayMemberPath="Nom"
                              Height="28" Margin="0,0,0,10"/>
                    <TextBlock Text="Facture d'origine (optionnel)" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Factures}" SelectedValuePath="Id"
                              SelectedValue="{Binding FactureOrigineId}" DisplayMemberPath="Numero"
                              Height="28" Margin="0,0,0,10"/>
                    <TextBlock Text="Montant à créditer ($) *" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Montant, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                    <TextBlock Text="Motif *" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Motif, UpdateSourceTrigger=PropertyChanged}"
                             Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Margin="0,0,0,10"/>
                </StackPanel>
                <Border Grid.Row="2" Padding="16,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="💾 Émettre avoir"
                                Command="{Binding SauvegarderCommand}"
                                Style="{StaticResource SuccessBtn}" Margin="0,0,6,0" Height="30"/>
                        <Button Grid.Column="1" Content="Annuler"
                                Command="{Binding AnnulerCommand}"
                                Style="{StaticResource SecondaryBtn}" Height="30"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
