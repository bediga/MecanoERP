<UserControl x:Class="MecanoERP.WPF.Views.ConfigTaxesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
            <StackPanel Orientation="Horizontal">
                <Border Width="4" Height="22" Background="#0070F2" CornerRadius="2" Margin="0,0,10,0"/>
                <TextBlock Text="Configuration des taxes" Style="{StaticResource PageTitle}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Ajouter configuration" Style="{StaticResource PrimaryBtn}" Height="28"/>
                <Button Content="🔄 Actualiser" Style="{StaticResource ToolBarBtn}" Height="28" Margin="6,0,0,0"
                        Command="{Binding ChargerCommand}"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" Margin="14,10,14,0"
                  ItemsSource="{Binding Configs}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Province"         Binding="{Binding Province}"                                  Width="110"/>
                <DataGridTextColumn Header="Régime"           Binding="{Binding Regime}"                                    Width="110"/>
                <DataGridTextColumn Header="TPS %"            Binding="{Binding TauxTPS,            StringFormat='{}{0:P2}'}" Width="90"/>
                <DataGridTextColumn Header="TVQ %"            Binding="{Binding TauxTVQ,            StringFormat='{}{0:P2}'}" Width="90"/>
                <DataGridTextColumn Header="Taux effectif"    Binding="{Binding TauxEffectifTotal,   StringFormat='{}{0:P2}'}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
