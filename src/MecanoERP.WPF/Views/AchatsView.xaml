<UserControl x:Class="MecanoERP.WPF.Views.AchatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                <StackPanel Orientation="Horizontal">
                    <Border Width="4" Height="22" Background="#E9730C" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="Achats — Demandes &amp; Bons de commande" Style="{StaticResource PageTitle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="➕ Nouvelle demande" Command="{Binding NouvelleDemandeCommand}"
                            Style="{StaticResource PrimaryBtn}" Height="28" Margin="0,0,6,0"/>
                    <Button Content="🔄 Actualiser" Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Height="28" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding MessageStatut}" Foreground="#107E3E"
                               FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="2" Margin="14,10,14,0"
                      ItemsSource="{Binding Demandes}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N° Demande"  Binding="{Binding Numero}"           Width="140"/>
                    <DataGridTextColumn Header="Demandeur"   Binding="{Binding Demandeur.Nom}"    Width="130"/>
                    <DataGridTextColumn Header="Date"        Binding="{Binding DateDemande, StringFormat=dd/MM/yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Statut"      Binding="{Binding Statut}"           Width="160"/>
                    <DataGridTextColumn Header="BC associé"  Binding="{Binding CommandeAchat.Numero}" Width="130"/>
                    <DataGridTemplateColumn Header="Actions" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✔ Approuver" Style="{StaticResource SuccessBtn}"
                                            Margin="0,0,4,0" Height="22" FontSize="11"
                                            Command="{Binding DataContext.ApprouverCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="📋 Créer BC" Style="{StaticResource PrimaryBtn}"
                                            Margin="0,0,4,0" Height="22" FontSize="11"
                                            Command="{Binding DataContext.CreerBCCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="🗑" Style="{StaticResource DangerBtn}"
                                            Height="22" FontSize="11" Width="28"
                                            Command="{Binding DataContext.SupprimerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="3"
                         Foreground="#E9730C" Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- Formulaire -->
        <Border Grid.Column="1" Width="280" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="1,0,0,0"
                Visibility="{Binding AfficherFormulaire, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#E9730C" Padding="16,12">
                    <TextBlock Text="Demande d'achat" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="14"/>
                </Border>
                <StackPanel Grid.Row="1" Margin="16,14,16,0">
                    <TextBlock Text="Demandeur" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Employes}" SelectedValuePath="Id"
                              SelectedValue="{Binding DemandeurId}" Height="28" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} {1}">
                                            <Binding Path="Nom"/><Binding Path="Prenom"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="Notes / Justification" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Margin="0,0,0,10"/>
                </StackPanel>
                <Border Grid.Row="2" Padding="16,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="💾 Créer"
                                Command="{Binding SauvegarderCommand}"
                                Style="{StaticResource SuccessBtn}" Margin="0,0,6,0" Height="30"/>
                        <Button Grid.Column="1" Content="Annuler"
                                Command="{Binding AnnulerCommand}"
                                Style="{StaticResource SecondaryBtn}" Height="30"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
