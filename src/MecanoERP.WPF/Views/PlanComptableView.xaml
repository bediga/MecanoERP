<UserControl x:Class="MecanoERP.WPF.Views.PlanComptableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                <StackPanel Orientation="Horizontal">
                    <Border Width="4" Height="22" Background="#0070F2" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="Plan comptable" Style="{StaticResource PageTitle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="➕ Nouveau compte" Command="{Binding NouveauCompteCommand}"
                            Style="{StaticResource PrimaryBtn}" Height="28" Margin="0,0,6,0"/>
                    <Button Content="🔄 Actualiser" Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Height="28"/>
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="2" Margin="14,10,14,0"
                      ItemsSource="{Binding Comptes}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N° Compte"  Binding="{Binding Numero}"      Width="100"/>
                    <DataGridTextColumn Header="Nom"        Binding="{Binding Nom}"          Width="*"/>
                    <DataGridTextColumn Header="Type"       Binding="{Binding TypeCompte}"   Width="140"/>
                    <DataGridTextColumn Header="Solde"      Binding="{Binding Solde, StringFormat=C}" Width="120"/>
                    <DataGridTextColumn Header="Actif"      Binding="{Binding EstActif}"     Width="70"/>
                    <DataGridTemplateColumn Header="Actions" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏" Style="{StaticResource ToolBarBtn}" Height="22" Width="26" Margin="0,0,4,0"
                                            Command="{Binding DataContext.ModifierCompteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="🗑" Style="{StaticResource DangerBtn}" Height="22" Width="26"
                                            Command="{Binding DataContext.SupprimerCompteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="3"
                         Foreground="#0070F2" Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- Formulaire -->
        <Border Grid.Column="1" Width="280" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="1,0,0,0"
                Visibility="{Binding AfficherFormulaire, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#0070F2" Padding="16,12">
                    <TextBlock Text="Compte GL" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="14"/>
                </Border>
                <StackPanel Grid.Row="1" Margin="16,14,16,0">
                    <TextBlock Text="N° de compte *" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Numero, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                    <TextBlock Text="Nom *" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding NomCompte, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                    <TextBlock Text="Type de compte *" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding TypesCompte}" SelectedItem="{Binding TypeCompte}"
                              Height="28" Margin="0,0,0,10"/>
                    <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Margin="0,0,0,10"/>
                    <CheckBox Content="Compte actif" IsChecked="{Binding EstActif}" Margin="0,0,0,10"/>
                </StackPanel>
                <Border Grid.Row="2" Padding="16,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="💾 Sauvegarder"
                                Command="{Binding SauvegarderCompteCommand}"
                                Style="{StaticResource SuccessBtn}" Margin="0,0,6,0" Height="30"/>
                        <Button Grid.Column="1" Content="Annuler"
                                Command="{Binding AnnulerCommand}"
                                Style="{StaticResource SecondaryBtn}" Height="30"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
