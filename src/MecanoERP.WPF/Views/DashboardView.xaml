<UserControl x:Class="MecanoERP.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Barre titre ── -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="4" Height="22" Background="#0070F2" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="Tableau de bord" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="{Binding DateAffichage}" FontFamily="Segoe UI" FontSize="13"
                               Foreground="#888" VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Height="3" Width="120"
                                 Foreground="#0070F2" Background="Transparent" BorderThickness="0"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="↻ Actualiser" Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Margin="10,0,0,0" Height="26"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,14,16,16">

                <!-- ═══ LIGNE 1 : KPIs Opérationnels (5 tuiles) ═══ -->
                <UniformGrid Columns="5" Margin="0,0,0,12">

                    <!-- OT En cours -->
                    <Border Background="White" BorderBrush="#E9730C" BorderThickness="1,1,1,3" CornerRadius="4"
                            Padding="14,12" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="🔧 ORDRES EN COURS" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Text="{Binding OtEnCours}" Style="{StaticResource KpiValue}" Foreground="#E9730C"/>
                            <ProgressBar Value="{Binding OtEnCours}" Maximum="20" Height="3" Margin="0,5,0,5"
                                         Foreground="#E9730C" Background="#FFF0E0" BorderThickness="0"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding OtAttentePieces, StringFormat='⏳ {0} att. pièces'}"
                                           FontSize="10" Foreground="#BB0000" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding OtPret, StringFormat='✅ {0} prêts'}"
                                           FontSize="10" Foreground="#107E3E"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- RDV du jour -->
                    <Border Background="White" BorderThickness="1,1,1,3" CornerRadius="4"
                            Padding="14,12" Margin="0,0,8,0">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#6D3FBE"/>
                        </Border.BorderBrush>
                        <StackPanel>
                            <TextBlock Text="📅 RENDEZ-VOUS" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Text="{Binding RdvAujourdhui}" Style="{StaticResource KpiValue}" Foreground="#6D3FBE"/>
                            <TextBlock Text="aujourd'hui" FontSize="11" Foreground="#AAAAAA"/>
                        </StackPanel>
                    </Border>

                    <!-- Clients -->
                    <Border Background="White" BorderBrush="#0070F2" BorderThickness="1,1,1,3" CornerRadius="4"
                            Padding="14,12" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="👥 CLIENTS" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Text="{Binding NombreClients}" Style="{StaticResource KpiValue}" Foreground="#0070F2"/>
                            <TextBlock Text="enregistrés" FontSize="11" Foreground="#AAAAAA"/>
                        </StackPanel>
                    </Border>

                    <!-- Stock critique -->
                    <Border Background="White" BorderBrush="#BB0000" BorderThickness="1,1,1,3" CornerRadius="4"
                            Padding="14,12" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="📦 STOCK CRITIQUE" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Text="{Binding PiecesStockCritique}" Style="{StaticResource KpiValue}" Foreground="#BB0000"/>
                            <TextBlock Text="pièces à réappro." FontSize="11" Foreground="#AAAAAA"/>
                        </StackPanel>
                    </Border>

                    <!-- Factures impayées -->
                    <Border Background="White" BorderBrush="#107E3E" BorderThickness="1,1,1,3" CornerRadius="4"
                            Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="💸 FACTURES" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Text="{Binding FacturesImpayees}" Style="{StaticResource KpiValue}" Foreground="#107E3E"/>
                            <TextBlock Text="en attente de règlement" FontSize="11" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- ═══ LIGNE 2 : KPIs Financiers ═══ -->
                <UniformGrid Columns="2" Margin="0,0,0,12">
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Padding="14,10" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="40" Height="40" Background="#EFF6FF" CornerRadius="20" Margin="0,0,12,0">
                                <TextBlock Text="📊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="CA DU JOUR" Style="{StaticResource KpiLabel}"/>
                                <TextBlock Text="{Binding ChiffreAffaireJour, StringFormat='{}{0:C}'}"
                                           FontSize="20" FontFamily="Segoe UI Semibold" Foreground="#0070F2"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="40" Height="40" Background="#EDFFF5" CornerRadius="20" Margin="0,0,12,0">
                                <TextBlock Text="📈" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="CA DU MOIS" Style="{StaticResource KpiLabel}"/>
                                <TextBlock Text="{Binding ChiffreAffaireMois, StringFormat='{}{0:C}'}"
                                           FontSize="20" FontFamily="Segoe UI Semibold" Foreground="#107E3E"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- ═══ LIGNE 3 : OTs actifs + RDV du jour ═══ -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- OTs actifs -->
                    <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#FFF8F0" BorderBrush="#EECFA0" BorderThickness="0,0,0,1"
                                    Padding="14,9" CornerRadius="4,4,0,0">
                                <TextBlock Text="🔧  Ordres de travail actifs" FontFamily="Segoe UI Semibold"
                                           FontSize="13" Foreground="#C05000"/>
                            </Border>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding OtsActifs}"
                                      IsReadOnly="True" AutoGenerateColumns="False"
                                      BorderThickness="0" GridLinesVisibility="Horizontal"
                                      MaxHeight="200" FontSize="12">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="N°" Binding="{Binding Numero}" Width="80"/>
                                    <DataGridTextColumn Header="Véhicule" Binding="{Binding Vehicule.Marque, StringFormat='{}{0}'}" Width="90"/>
                                    <DataGridTextColumn Header="Client" Binding="{Binding Vehicule.Client.Prenom}" Width="80"/>
                                    <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="110"/>
                                    <DataGridTextColumn Header="Entré le" Binding="{Binding DateEntree, StringFormat='dd/MM HH:mm'}" Width="90"/>
                                    <DataGridTextColumn Header="Technicien" Binding="{Binding Employe.Prenom}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- RDV du jour -->
                    <Border Grid.Column="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#F5F0FF" BorderBrush="#C9B0E0" BorderThickness="0,0,0,1"
                                    Padding="14,9" CornerRadius="4,4,0,0">
                                <TextBlock Text="📅  Rendez-vous du jour" FontFamily="Segoe UI Semibold"
                                           FontSize="13" Foreground="#5A2A9E"/>
                            </Border>
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding RdvDuJour}" Margin="0,4,0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="10,3" Padding="10,7" Background="#FAFAFA"
                                                BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="#EAE0FF" CornerRadius="3"
                                                        Width="38" Height="38" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding DateHeure, StringFormat='HH:mm'}"
                                                               FontSize="11" FontFamily="Segoe UI Semibold"
                                                               Foreground="#6D3FBE"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Client.Prenom}" FontFamily="Segoe UI Semibold" FontSize="12"/>
                                                    <TextBlock Text="{Binding Vehicule.Marque}" FontSize="11" Foreground="#888"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ═══ LIGNE 4 : Alertes stock + Factures récentes ═══ -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Alertes stock critique -->
                    <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#FFF0F0" BorderBrush="#FFCCCC" BorderThickness="0,0,0,1"
                                    Padding="14,9" CornerRadius="4,4,0,0">
                                <TextBlock Text="⚠  Stock critique" FontFamily="Segoe UI Semibold"
                                           FontSize="13" Foreground="#BB0000"/>
                            </Border>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding PiecesAlertes}"
                                      IsReadOnly="True" AutoGenerateColumns="False"
                                      BorderThickness="0" GridLinesVisibility="Horizontal"
                                      MaxHeight="170" FontSize="12">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Référence" Binding="{Binding Reference}" Width="90"/>
                                    <DataGridTextColumn Header="Désignation" Binding="{Binding Nom}" Width="*"/>
                                    <DataGridTextColumn Header="Stock" Binding="{Binding StockActuel}" Width="52"/>
                                    <DataGridTextColumn Header="Min." Binding="{Binding StockMinimum}" Width="45"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Factures récentes -->
                    <Border Grid.Column="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#F0FFF4" BorderBrush="#C8E6C9" BorderThickness="0,0,0,1"
                                    Padding="14,9" CornerRadius="4,4,0,0">
                                <TextBlock Text="🧾  Factures récentes" FontFamily="Segoe UI Semibold"
                                           FontSize="13" Foreground="#107E3E"/>
                            </Border>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding FacturesRecentes}"
                                      IsReadOnly="True" AutoGenerateColumns="False"
                                      BorderThickness="0" GridLinesVisibility="Horizontal"
                                      MaxHeight="170" FontSize="12">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="N°" Binding="{Binding Numero}" Width="80"/>
                                    <DataGridTextColumn Header="Client" Binding="{Binding Client.Prenom}" Width="*"/>
                                    <DataGridTextColumn Header="Montant TTC" Binding="{Binding MontantTTC, StringFormat='{}{0:C}'}" Width="90"/>
                                    <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="80"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding DateFacture, StringFormat='dd/MM/yy'}" Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
