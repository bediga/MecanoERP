<UserControl x:Class="MecanoERP.WPF.Views.InventaireView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                <StackPanel Orientation="Horizontal">
                    <Border Width="4" Height="22" Background="#0070F2" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="Inventaire" Style="{StaticResource PageTitle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding Recherche, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                    <Button Grid.Column="1" Content="🔍 Chercher" Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Margin="6,0,0,0" Height="28"/>
                    <Button Grid.Column="3" Content="➕ Nouvelle pièce"
                            Command="{Binding NouvellePieceCommand}"
                            Style="{StaticResource PrimaryBtn}" Height="28" Margin="0,0,6,0"/>
                    <Button Grid.Column="4" Content="🔄 Actualiser" Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Height="28"/>
                </Grid>
            </Border>

            <DataGrid Grid.Row="2" Margin="14,10,14,0"
                      ItemsSource="{Binding Pieces}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Référence"    Binding="{Binding Reference}"         Width="120"/>
                    <DataGridTextColumn Header="Désignation"  Binding="{Binding Designation}"       Width="200"/>
                    <DataGridTextColumn Header="Stock"        Binding="{Binding StockActuel}"       Width="70"/>
                    <DataGridTextColumn Header="Min"          Binding="{Binding StockMinimum}"      Width="60"/>
                    <DataGridTextColumn Header="Prix vente"   Binding="{Binding PrixVente, StringFormat=C}" Width="100"/>
                    <DataGridTextColumn Header="Fournisseur"  Binding="{Binding Fournisseur.Nom}"   Width="140"/>
                    <DataGridTemplateColumn Header="Actions" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏ Modifier" Style="{StaticResource ToolBarBtn}"
                                            Margin="0,0,4,0" Height="22" FontSize="11"
                                            Command="{Binding DataContext.ModifierPieceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="📦 Stock" Style="{StaticResource ToolBarBtn}"
                                            Height="22" FontSize="11"
                                            Command="{Binding DataContext.OuvrirAjustementCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StockActuel}" Value="0">
                                <Setter Property="Background" Value="#FFF0F0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="3"
                         Foreground="#0070F2" Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- Formulaire pièce -->
        <Border Grid.Column="1" Width="300" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="1,0,0,0"
                Visibility="{Binding AfficherFormulaire, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#0070F2" Padding="16,12">
                    <TextBlock Text="Fiche Pièce" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="14"/>
                </Border>
                <ScrollViewer Grid.Row="1">
                    <StackPanel Margin="16,14,16,0">
                        <TextBlock Text="Référence *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Reference, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Désignation *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Designation, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Catégorie" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Height="28" Margin="0,0,0,10" IsEditable="True" Text="{Binding Categorie}">
                            <ComboBoxItem>Freinage</ComboBoxItem>
                            <ComboBoxItem>Moteur</ComboBoxItem>
                            <ComboBoxItem>Suspension</ComboBoxItem>
                            <ComboBoxItem>Électricité</ComboBoxItem>
                            <ComboBoxItem>Carrosserie</ComboBoxItem>
                            <ComboBoxItem>Filtres</ComboBoxItem>
                            <ComboBoxItem>Huiles / Fluides</ComboBoxItem>
                            <ComboBoxItem>Autre</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Text="Emplacement" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Emplacement, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Fournisseur" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding Fournisseurs}"
                                  SelectedValuePath="Id" SelectedValue="{Binding FournisseurId}"
                                  DisplayMemberPath="Nom"
                                  Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Prix d'achat ($)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding PrixAchat, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Prix de vente ($)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding PrixVente, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Stock actuel" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding StockActuel, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Stock minimum" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding StockMinimum, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                    </StackPanel>
                </ScrollViewer>
                <Border Grid.Row="2" Padding="16,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="💾 Sauvegarder"
                                Command="{Binding SauvegarderCommand}"
                                Style="{StaticResource SuccessBtn}" Margin="0,0,6,0" Height="30"/>
                        <Button Grid.Column="1" Content="Annuler"
                                Command="{Binding AnnulerCommand}"
                                Style="{StaticResource SecondaryBtn}" Height="30"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
