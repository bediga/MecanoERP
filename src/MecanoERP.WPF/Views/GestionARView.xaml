<UserControl x:Class="MecanoERP.WPF.Views.GestionARView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,10">
            <StackPanel Orientation="Horizontal">
                <Border Width="4" Height="22" Background="#0070F2" CornerRadius="2" Margin="0,0,10,0"/>
                <TextBlock Text="👥 Comptes Clients (AR)" Style="{StaticResource PageTitle}"/>
                <ProgressBar IsIndeterminate="True" Height="3" Width="60" Margin="16,0,0,0"
                             VerticalAlignment="Center" Foreground="#0070F2" Background="Transparent"
                             BorderThickness="0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </Border>

        <!-- KPIs -->
        <Grid Grid.Row="1" Margin="16,10,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <!-- Total AR -->
            <Border Grid.Column="0" Background="White" BorderBrush="#0070F2" BorderThickness="0,3,0,0" CornerRadius="4" Padding="14,10" Margin="0,0,8,8" Effect="{StaticResource ShadowSmall}">
                <StackPanel>
                    <TextBlock Text="Total AR" FontSize="11" Foreground="#888"/>
                    <TextBlock Text="{Binding TotalAR, StringFormat='{}{0:N0} $'}" FontSize="22" FontFamily="Segoe UI Semibold" Foreground="#0070F2" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <!-- Échues auj. -->
            <Border Grid.Column="1" Background="White" BorderBrush="#E9730C" BorderThickness="0,3,0,0" CornerRadius="4" Padding="14,10" Margin="0,0,8,8" Effect="{StaticResource ShadowSmall}">
                <StackPanel>
                    <TextBlock Text="Échues auj." FontSize="11" Foreground="#888"/>
                    <TextBlock Text="{Binding EchuesToday, StringFormat='{}{0:N0} $'}" FontSize="22" FontFamily="Segoe UI Semibold" Foreground="#E9730C" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <!-- En souffrance 90j+ -->
            <Border Grid.Column="2" Background="White" BorderBrush="#BB0000" BorderThickness="0,3,0,0" CornerRadius="4" Padding="14,10" Margin="0,0,8,8" Effect="{StaticResource ShadowSmall}">
                <StackPanel>
                    <TextBlock Text="90j+ en souffrance" FontSize="11" Foreground="#888"/>
                    <TextBlock Text="{Binding EnSouffrance90, StringFormat='{}{0:N0} $'}" FontSize="22" FontFamily="Segoe UI Semibold" Foreground="#BB0000" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <!-- En retard -->
            <Border Grid.Column="3" Background="White" BorderBrush="#555" BorderThickness="0,3,0,0" CornerRadius="4" Padding="14,10" Margin="0,0,8,8" Effect="{StaticResource ShadowSmall}">
                <StackPanel>
                    <TextBlock Text="Clients en retard" FontSize="11" Foreground="#888"/>
                    <TextBlock Text="{Binding NombreEnRetard}" FontSize="22" FontFamily="Segoe UI Semibold" Foreground="#333" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <!-- Taux recouvrement -->
            <Border Grid.Column="4" Background="White" BorderBrush="#107E3E" BorderThickness="0,3,0,0" CornerRadius="4" Padding="14,10" Margin="0,0,0,8" Effect="{StaticResource ShadowSmall}">
                <StackPanel>
                    <TextBlock Text="Taux recouvrement" FontSize="11" Foreground="#888"/>
                    <TextBlock Text="{Binding TauxRecouvrement, StringFormat='{}{0:N1}%'}" FontSize="22" FontFamily="Segoe UI Semibold" Foreground="#107E3E" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Onglets -->
        <TabControl Grid.Row="2" Margin="16,8,16,16" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">

            <!-- ── Aging AR ── -->
            <TabItem Header="📊 Rapport d'âge AR">
                <DataGrid ItemsSource="{Binding LignesAging}" IsReadOnly="True" AutoGenerateColumns="False"
                          BorderThickness="0" GridLinesVisibility="Horizontal" AlternatingRowBackground="#F7F9FC" FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Client"     Binding="{Binding ClientNom}"  Width="*"/>
                        <DataGridTextColumn Header="Courant"    Binding="{Binding Courant,    StringFormat='{}{0:N2}'}" Width="110"/>
                        <DataGridTextColumn Header="1-30 j"     Binding="{Binding Jours0_30,  StringFormat='{}{0:N2}'}" Width="100"/>
                        <DataGridTextColumn Header="31-60 j"    Binding="{Binding Jours31_60, StringFormat='{}{0:N2}'}" Width="100"/>
                        <DataGridTextColumn Header="61-90 j"    Binding="{Binding Jours61_90, StringFormat='{}{0:N2}'}" Width="100"/>
                        <DataGridTextColumn Header="90+ j"      Binding="{Binding Plus90,     StringFormat='{}{0:N2}'}" Width="100"/>
                        <DataGridTextColumn Header="Total $"    Binding="{Binding Total,      StringFormat='{}{0:N2}'}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ── Encaissements ── -->
            <TabItem Header="💵 Encaissements">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Saisie rapide -->
                    <Border Grid.Row="0" Background="#F7F9FC" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="14,10" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Facture :" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12" Foreground="#555"/>
                            <ComboBox ItemsSource="{Binding Factures}" SelectedItem="{Binding FactureSelectionnee}" Width="220" Height="28" Margin="0,0,12,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock><Run Text="{Binding Numero}"/> — <Run Text="{Binding Client.Prenom}"/> <Run Text="{Binding Client.Nom}"/></TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="Montant :" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12" Foreground="#555"/>
                            <TextBox Text="{Binding MontantEncaissement}" Width="100" Height="28" Margin="0,0,12,0"/>
                            <TextBlock Text="Mode :" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12" Foreground="#555"/>
                            <ComboBox ItemsSource="{Binding ModesPaiement}" SelectedItem="{Binding ModeEncaissement}" Width="110" Height="28" Margin="0,0,12,0"/>
                            <TextBlock Text="Réf. :" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12" Foreground="#555"/>
                            <TextBox Text="{Binding ReferenceEncaissement}" Width="120" Height="28" Margin="0,0,12,0"/>
                            <Button Content="✅ Enregistrer" Command="{Binding EncaisserCommand}"
                                    Style="{StaticResource PrimaryBtn}" Height="28" Padding="14,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Message -->
                    <TextBlock Grid.Row="1" Text="{Binding Message}" FontSize="13" Foreground="#333" Margin="4,0"/>
                </Grid>
            </TabItem>

            <!-- ── Relances ── -->
            <TabItem Header="📬 Relances">
                <DataGrid ItemsSource="{Binding ClientsEnRetard}" IsReadOnly="True" AutoGenerateColumns="False"
                          BorderThickness="0" GridLinesVisibility="Horizontal" AlternatingRowBackground="#F7F9FC" FontSize="12">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Niveau}" Value="3">
                                    <Setter Property="Background" Value="#FFF0F0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Niveau}" Value="2">
                                    <Setter Property="Background" Value="#FFF8F0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Client"          Binding="{Binding Nom}"              Width="*"/>
                        <DataGridTextColumn Header="Téléphone"       Binding="{Binding Telephone}"        Width="120"/>
                        <DataGridTextColumn Header="Email"           Binding="{Binding Email}"            Width="180"/>
                        <DataGridTextColumn Header="Nb factures"     Binding="{Binding NombreFactures}"   Width="90"/>
                        <DataGridTextColumn Header="Solde échu $"    Binding="{Binding SoldeEchu, StringFormat='{}{0:N2}'}" Width="110"/>
                        <DataGridTextColumn Header="Jours retard"    Binding="{Binding JoursRetard}"      Width="90"/>
                        <DataGridTextColumn Header="Niveau relance"  Binding="{Binding Niveau}"           Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
