<UserControl x:Class="MecanoERP.WPF.Views.VehiculesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ── Panneau liste ── -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titre -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                <StackPanel Orientation="Horizontal">
                    <Border Width="4" Height="22" Background="#0070F2" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="Véhicules" Style="{StaticResource PageTitle}"/>
                </StackPanel>
            </Border>

            <!-- Barre d'outils -->
            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding Recherche, UpdateSourceTrigger=PropertyChanged}"
                             Height="28"/>
                    <Button Grid.Column="1" Content="🔍 Chercher" Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Margin="6,0,0,0" Height="28"/>
                    <Button Grid.Column="3" Content="➕ Nouveau véhicule"
                            Command="{Binding NouveauVehiculeCommand}"
                            Style="{StaticResource PrimaryBtn}" Height="28" Margin="0,0,6,0"/>
                    <Button Grid.Column="4" Content="🔄 Actualiser"
                            Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Height="28"/>
                </Grid>
            </Border>

            <!-- DataGrid -->
            <DataGrid Grid.Row="2" Margin="14,10,14,0"
                      ItemsSource="{Binding Vehicules}"
                      SelectedItem="{Binding Selection}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Marque"        Binding="{Binding Marque}"         Width="120"/>
                    <DataGridTextColumn Header="Modèle"        Binding="{Binding Modele}"         Width="130"/>
                    <DataGridTextColumn Header="Année"         Binding="{Binding Annee}"          Width="70"/>
                    <DataGridTextColumn Header="Immatriculation" Binding="{Binding Immatriculation}" Width="130"/>
                    <DataGridTextColumn Header="Client"        Binding="{Binding Client.Nom}"     Width="150"/>
                    <DataGridTextColumn Header="Km"            Binding="{Binding Kilometrage, StringFormat=N0}" Width="90"/>
                    <DataGridTemplateColumn Header="Actions" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏ Modifier" Style="{StaticResource ToolBarBtn}"
                                            Margin="0,0,4,0" Height="22" FontSize="11"
                                            Command="{Binding DataContext.ModifierVehiculeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="🗑 Supprimer" Style="{StaticResource DangerBtn}"
                                            Height="22" FontSize="11"
                                            Command="{Binding DataContext.SupprimerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="3"
                         Foreground="#0070F2" Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- ── Formulaire latéral ── -->
        <Border Grid.Column="1" Width="320" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="1,0,0,0"
                Visibility="{Binding AfficherFormulaire, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Header -->
                <Border Grid.Row="0" Background="#0070F2" Padding="16,12">
                    <TextBlock Text="Fiche Véhicule" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="14"/>
                </Border>
                <!-- Champs -->
                <ScrollViewer Grid.Row="1">
                    <StackPanel Margin="16,14,16,0">
                        <TextBlock Text="Client *" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding Clients}"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedClientId}"
                                  DisplayMemberPath="Nom"
                                  Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Marque *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Marque, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Modèle *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Modele, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Année" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Annee, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Immatriculation" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Immatriculation, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="VIN" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Vin, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Kilométrage" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Kilometrage, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Type de moteur" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Height="28" Margin="0,0,0,10"
                                  Text="{Binding TypeMoteur}"
                                  IsEditable="True">
                            <ComboBoxItem>Essence</ComboBoxItem>
                            <ComboBoxItem>Diesel</ComboBoxItem>
                            <ComboBoxItem>Hybride</ComboBoxItem>
                            <ComboBoxItem>Électrique</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Text="Transmission" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Height="28" Margin="0,0,0,10"
                                  Text="{Binding Transmission}"
                                  IsEditable="True">
                            <ComboBoxItem>Automatique</ComboBoxItem>
                            <ComboBoxItem>Manuelle</ComboBoxItem>
                            <ComboBoxItem>CVT</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Text="Couleur" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Couleur, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                    </StackPanel>
                </ScrollViewer>
                <!-- Boutons -->
                <Border Grid.Row="2" Padding="16,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="💾 Sauvegarder"
                                Command="{Binding SauvegarderCommand}"
                                Style="{StaticResource SuccessBtn}" Margin="0,0,6,0" Height="30"/>
                        <Button Grid.Column="1" Content="Annuler"
                                Command="{Binding AnnulerCommand}"
                                Style="{StaticResource SecondaryBtn}" Height="30"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
