<UserControl x:Class="MecanoERP.WPF.Views.RapportsComptablesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
            <StackPanel Orientation="Horizontal">
                <Border Width="4" Height="22" Background="#BB0000" CornerRadius="2" Margin="0,0,10,0"/>
                <TextBlock Text="Rapports &amp; Tableaux de bord financiers" Style="{StaticResource PageTitle}"/>
            </StackPanel>
        </Border>

        <!-- Filtres période + type rapport -->
        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Rapport :" VerticalAlignment="Center" FontSize="12" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding TypesRapport}" SelectedItem="{Binding TypeRapportSelectionne}"
                          Width="200" Height="26" Margin="0,0,10,0"/>
                <TextBlock Text="Du :" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
                <DatePicker SelectedDate="{Binding DateDebut}" Height="26" Width="110" Margin="0,0,4,0"
                            FontSize="12" FontFamily="Segoe UI"/>
                <TextBlock Text="Au :" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
                <DatePicker SelectedDate="{Binding DateFin}" Height="26" Width="110" Margin="0,0,8,0"
                            FontSize="12" FontFamily="Segoe UI"/>
                <Button Content="📊 Générer" Command="{Binding GenererRapportCommand}"
                        Style="{StaticResource PrimaryBtn}" Height="26" Width="90"/>
                <Button Content="📄 Export CSV" Command="{Binding ExporterCSVCommand}"
                        Style="{StaticResource ToolBarBtn}" Height="26" Margin="6,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Zone rapport -->
        <ScrollViewer Grid.Row="2" Margin="14,10,14,10">
            <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource InvertBoolToVisibility}}">

                <!-- KPIs résumé -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Padding="14,10" Margin="0,0,8,0" MinWidth="140">
                        <StackPanel>
                            <TextBlock Text="Chiffre d'affaires" FontSize="11" Foreground="#6E6E6E"/>
                            <TextBlock Text="{Binding KpiCA, StringFormat=C}" FontSize="20" FontWeight="Bold" Foreground="#0070F2"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Padding="14,10" Margin="0,0,8,0" MinWidth="140">
                        <StackPanel>
                            <TextBlock Text="Marge brute" FontSize="11" Foreground="#6E6E6E"/>
                            <TextBlock Text="{Binding KpiMarge, StringFormat=C}" FontSize="20" FontWeight="Bold" Foreground="#107E3E"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Padding="14,10" Margin="0,0,8,0" MinWidth="140">
                        <StackPanel>
                            <TextBlock Text="À recevoir (AR)" FontSize="11" Foreground="#6E6E6E"/>
                            <TextBlock Text="{Binding KpiAR, StringFormat=C}" FontSize="20" FontWeight="Bold" Foreground="#E9730C"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Padding="14,10" Margin="0,0,8,0" MinWidth="140">
                        <StackPanel>
                            <TextBlock Text="À payer (AP)" FontSize="11" Foreground="#6E6E6E"/>
                            <TextBlock Text="{Binding KpiAP, StringFormat=C}" FontSize="20" FontWeight="Bold" Foreground="#BB0000"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Padding="14,10" MinWidth="140">
                        <StackPanel>
                            <TextBlock Text="Solde bancaire" FontSize="11" Foreground="#6E6E6E"/>
                            <TextBlock Text="{Binding KpiBanque, StringFormat=C}" FontSize="20" FontWeight="Bold" Foreground="#107E3E"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Tableau de détails du rapport -->
                <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="0">
                    <StackPanel>
                        <Border Padding="14,10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding TitreTableau}" FontFamily="Segoe UI Semibold" FontSize="13"/>
                        </Border>
                        <DataGrid ItemsSource="{Binding LignesRapport}"
                                  IsReadOnly="True" BorderThickness="0"
                                  Background="Transparent"
                                  AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="Qté / N°"    Binding="{Binding Quantite}"    Width="90"/>
                                <DataGridTextColumn Header="Montant"     Binding="{Binding Montant, StringFormat=C}" Width="130"/>
                                <DataGridTextColumn Header="%" Binding="{Binding PourcentageStr}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
