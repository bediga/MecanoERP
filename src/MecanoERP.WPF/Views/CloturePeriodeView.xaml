<UserControl x:Class="MecanoERP.WPF.Views.CloturePeriodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,10">
            <StackPanel Orientation="Horizontal">
                <Border Width="4" Height="22" Background="#E9730C" CornerRadius="2" Margin="0,0,10,0"/>
                <TextBlock Text="🔒 Clôture des périodes" Style="{StaticResource PageTitle}"/>
            </StackPanel>
        </Border>

        <!-- Contrôles exercice -->
        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="16,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Exercice :" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#555" FontSize="12"/>
                <TextBox Text="{Binding Exercice}" Width="80" Height="28" Margin="0,0,12,0"/>
                <Button Content="📅 Charger périodes"   Command="{Binding ChargerCommand}"
                        Style="{StaticResource ToolBarBtn}" Height="28" Margin="0,0,8,0"/>
                <Button Content="➕ Initialiser exercice" Command="{Binding InitialiserExerciceCommand}"
                        Style="{StaticResource ToolBarBtn}" Height="28" Margin="0,0,8,0"/>
                <Button Content="🔒 Fermer période séléctionnée" Command="{Binding FermerPeriodeCommand}"
                        Background="#E9730C" Foreground="White" BorderThickness="0"
                        Height="28" Padding="12,0" Cursor="Hand" Margin="0,0,0,0"/>
                <ProgressBar IsIndeterminate="True" Height="3" Width="80" Margin="12,0,0,0"
                             VerticalAlignment="Center" Foreground="#0070F2" Background="Transparent"
                             BorderThickness="0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </Border>

        <!-- Liste des 12 périodes -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Periodes}"
                  SelectedItem="{Binding PeriodeSelectionnee}"
                  IsReadOnly="True" AutoGenerateColumns="False"
                  BorderThickness="0" GridLinesVisibility="Horizontal"
                  SelectionMode="Single" FontSize="12">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Statut}" Value="Cloturee">
                            <Setter Property="Background" Value="#F5F5F5"/>
                            <Setter Property="Foreground" Value="#AAAAAA"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Statut}" Value="Fermee">
                            <Setter Property="Background" Value="#FFF8F0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Période"    Binding="{Binding Libelle}"                Width="80"/>
                <DataGridTextColumn Header="Exercice"   Binding="{Binding Exercice}"               Width="70"/>
                <DataGridTextColumn Header="Mois"       Binding="{Binding Periode}"                Width="50"/>
                <DataGridTextColumn Header="Début"      Binding="{Binding DateDebut, StringFormat='dd/MM/yyyy'}" Width="100"/>
                <DataGridTextColumn Header="Fin"        Binding="{Binding DateFin,   StringFormat='dd/MM/yyyy'}" Width="100"/>
                <DataGridTextColumn Header="Statut"     Binding="{Binding Statut}"                 Width="100"/>
                <DataGridTextColumn Header="Date clôture" Binding="{Binding DateCloture, StringFormat='dd/MM/yyyy HH:mm'}" Width="140"/>
                <DataGridTextColumn Header="Notes"      Binding="{Binding Notes}"                  Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Message statut -->
        <Border Grid.Row="3" Padding="16,8" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                Visibility="{Binding Message, Converter={StaticResource NotEmptyToVisibility}}">
            <TextBlock Text="{Binding Message}" FontFamily="Segoe UI" FontSize="13"
                       Foreground="#333" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
