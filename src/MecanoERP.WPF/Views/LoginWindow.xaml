<Window x:Class="MecanoERP.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MecanoERP — Connexion"
        Width="420" Height="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="White" CornerRadius="4">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" Opacity="0.18" ShadowDepth="4"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="4,4,0,0" Background="White"
                    BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                <Grid Margin="0">
                    <!-- Bouton fermer -->
                    <Button Content="✕" HorizontalAlignment="Right"
                            Width="36" Height="36"
                            Foreground="#888888" Background="Transparent"
                            BorderThickness="0" FontSize="14" Cursor="Hand"
                            Click="OnClose"
                            VerticalAlignment="Top"/>
                    <!-- Logo + titre -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,18,0,16">
                        <Image Source="/Assets/logo.png" Height="90"
                               HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Formulaire ── -->
            <StackPanel Grid.Row="1" Margin="36,28,36,28" MouseDown="OnTitleBarDrag">

                <!-- Identifiant -->
                <TextBlock Text="Identifiant" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtNom"
                         Text="{Binding NomUtilisateur, UpdateSourceTrigger=PropertyChanged}"
                         Height="32" Margin="0,0,0,14"/>

                <!-- Mot de passe -->
                <TextBlock Text="Mot de passe" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="txtPwd" Height="32" Margin="0,0,0,6"
                             PasswordChanged="OnPasswordChanged"/>

                <!-- Erreur -->
                <Border x:Name="erreurBorder"
                        Background="#FFF0F0" BorderBrush="#FFCCCC"
                        BorderThickness="1" CornerRadius="3"
                        Padding="8,6" Margin="0,6,0,0"
                        Visibility="{Binding MessageErreur, Converter={StaticResource NotEmptyToVisibility}}">
                    <TextBlock Text="{Binding MessageErreur}"
                               Foreground="#BB0000" FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Bouton connexion -->
                <Button Content="Se connecter"
                        Style="{StaticResource PrimaryBtn}"
                        Command="{Binding ConnecterCommand}"
                        Height="38" Margin="0,20,0,0"
                        FontSize="14" FontFamily="Segoe UI Semibold"/>

                <!-- Loading -->
                <ProgressBar IsIndeterminate="True" Height="3" Margin="0,8,0,0"
                             Foreground="#0070F2" Background="Transparent"
                             BorderThickness="0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>


            </StackPanel>
        </Grid>
    </Border>
</Window>
