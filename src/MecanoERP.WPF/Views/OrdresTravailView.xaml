<UserControl x:Class="MecanoERP.WPF.Views.OrdresTravailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titre -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                <StackPanel Orientation="Horizontal">
                    <Border Width="4" Height="22" Background="#0070F2" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="Ordres de travail" Style="{StaticResource PageTitle}"/>
                </StackPanel>
            </Border>

            <!-- Barre d'outils -->
            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="➕ Nouvel OT"
                            Command="{Binding NouvelOTCommand}"
                            Style="{StaticResource PrimaryBtn}" Height="28" Margin="0,0,6,0"/>
                    <Button Content="🔄 Actualiser"
                            Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Height="28"/>
                    <!-- Message statut -->
                    <TextBlock Text="{Binding MessageStatut}" Foreground="#107E3E" FontSize="12"
                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- DataGrid -->
            <DataGrid Grid.Row="2" Margin="14,10,14,0"
                      ItemsSource="{Binding Ordres}"
                      SelectedItem="{Binding Selection}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N° OT"       Binding="{Binding Numero}"            Width="140"/>
                    <DataGridTextColumn Header="Véhicule"    Binding="{Binding Vehicule.Immatriculation}" Width="120"/>
                    <DataGridTextColumn Header="Client"      Binding="{Binding Vehicule.Client.Nom}" Width="140"/>
                    <DataGridTextColumn Header="Technicien"  Binding="{Binding Employe.Nom}"        Width="120"/>
                    <DataGridTextColumn Header="Date"        Binding="{Binding DateEntree, StringFormat=dd/MM/yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Statut"      Binding="{Binding Statut}"             Width="100"/>
                    <DataGridTemplateColumn Header="Actions" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏ Modifier" Style="{StaticResource ToolBarBtn}"
                                            Margin="0,0,4,0" Height="22" FontSize="11"
                                            Command="{Binding DataContext.ModifierOTCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="⏩ Avancer" Style="{StaticResource ToolBarBtn}"
                                            Margin="0,0,4,0" Height="22" FontSize="11"
                                            Command="{Binding DataContext.ChangerStatutCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="🧾 Facturer" Style="{StaticResource SuccessBtn}"
                                            Height="22" FontSize="11"
                                            Command="{Binding DataContext.FacturerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="3"
                         Foreground="#0070F2" Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- ── Formulaire latéral ── -->
        <Border Grid.Column="1" Width="350" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="1,0,0,0"
                Visibility="{Binding AfficherFormulaire, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#0070F2" Padding="16,12">
                    <TextBlock Text="Ordre de Travail" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="14"/>
                </Border>
                <ScrollViewer Grid.Row="1">
                    <StackPanel Margin="16,14,16,0">
                        <TextBlock Text="Véhicule *" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding Vehicules}"
                                  SelectedValuePath="Id" SelectedValue="{Binding VehiculeId}"
                                  Height="28" Margin="0,0,0,10">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} {1} — {2}">
                                                <Binding Path="Marque"/>
                                                <Binding Path="Modele"/>
                                                <Binding Path="Immatriculation"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Technicien" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding Employes}"
                                  SelectedValuePath="Id" SelectedValue="{Binding EmployeId}"
                                  Height="28" Margin="0,0,0,10">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} {1}">
                                                <Binding Path="Nom"/>
                                                <Binding Path="Prenom"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Km à l'entrée" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding KilometrageEntree, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Diagnostic" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Diagnostic, UpdateSourceTrigger=PropertyChanged}"
                                 Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalContentAlignment="Top" Margin="0,0,0,10"/>

                        <TextBlock Text="Travaux demandés" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding TravauxDemandes, UpdateSourceTrigger=PropertyChanged}"
                                 Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalContentAlignment="Top" Margin="0,0,0,10"/>

                        <TextBlock Text="Temps estimé (h)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding TempsEstime, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <TextBlock Text="Notes" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Height="55" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalContentAlignment="Top" Margin="0,0,0,10"/>
                    </StackPanel>
                </ScrollViewer>
                <Border Grid.Row="2" Padding="16,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="💾 Sauvegarder"
                                Command="{Binding SauvegarderCommand}"
                                Style="{StaticResource SuccessBtn}" Margin="0,0,6,0" Height="30"/>
                        <Button Grid.Column="1" Content="Annuler"
                                Command="{Binding AnnulerCommand}"
                                Style="{StaticResource SecondaryBtn}" Height="30"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
