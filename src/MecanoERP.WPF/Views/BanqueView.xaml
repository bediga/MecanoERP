<UserControl x:Class="MecanoERP.WPF.Views.BanqueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panneau comptes bancaires -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#0070F2" Padding="14,12">
                    <TextBlock Text="Comptes bancaires" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="13"/>
                </Border>
                <Button Grid.Row="1" Content="➕ Nouveau compte"
                        Command="{Binding OuvrirNouveauCompteCommand}"
                        Style="{StaticResource ToolBarBtn}" Margin="8,8,8,4" Height="28"/>
                <ListBox Grid.Row="2" ItemsSource="{Binding Comptes}"
                         SelectedItem="{Binding CompteSelectionne}"
                         BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,4,4,4">
                                <TextBlock Text="{Binding Nom}" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="{Binding Institution}" Foreground="#6E6E6E" FontSize="11"/>
                                <TextBlock Foreground="#107E3E" FontSize="12">
                                    <TextBlock.Text>
                                        <Binding Path="SoldeCourant" StringFormat="{}{0:C}"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="8,4"/>
                            <EventSetter Event="Selected"
                                         Handler="CompteSelectionne_Selected"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!-- Panneau transactions -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- En-tête -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="16,12">
                <StackPanel Orientation="Horizontal">
                    <Border Width="4" Height="22" Background="#107E3E" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Style="{StaticResource PageTitle}">
                        <TextBlock.Text>
                            <Binding Path="CompteSelectionne.Nom" FallbackValue="Banque — Rapprochement"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Barre outils -->
            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="➕ Transaction" Command="{Binding OuvrirNouvelleTransactionCommand}"
                            Style="{StaticResource PrimaryBtn}" Height="28" Margin="0,0,6,0"/>
                    <Button Content="🔄 Actualiser" Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Height="28" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding MessageStatut}" Foreground="#107E3E"
                               FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- KPIs solde -->
            <Border Grid.Row="2" Background="#F7F9FC" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#E8F5E9" BorderBrush="#107E3E" BorderThickness="1" CornerRadius="3" Padding="10,6" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Crédits" Foreground="#107E3E" FontSize="11"/>
                            <TextBlock Text="{Binding CreditsSolde, StringFormat=C}" FontWeight="SemiBold" Foreground="#107E3E" FontSize="14"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFEBEE" BorderBrush="#BB0000" BorderThickness="1" CornerRadius="3" Padding="10,6" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Débits" Foreground="#BB0000" FontSize="11"/>
                            <TextBlock Text="{Binding DebitsSolde, StringFormat=C}" FontWeight="SemiBold" Foreground="#BB0000" FontSize="14"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#E3F2FD" BorderBrush="#0070F2" BorderThickness="1" CornerRadius="3" Padding="10,6">
                        <StackPanel>
                            <TextBlock Text="Solde net" Foreground="#0070F2" FontSize="11"/>
                            <TextBlock Text="{Binding SoldeCourant, StringFormat=C}" FontWeight="SemiBold" Foreground="#0070F2" FontSize="14"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Transactions -->
            <DataGrid Grid.Row="3" Margin="14,10,14,0"
                      ItemsSource="{Binding Transactions}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date"         Binding="{Binding Date, StringFormat=dd/MM/yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Description"  Binding="{Binding Description}"  Width="*"/>
                    <DataGridTextColumn Header="Référence"    Binding="{Binding Reference}"     Width="120"/>
                    <DataGridTextColumn Header="Type"         Binding="{Binding TypeTx}"        Width="80"/>
                    <DataGridTextColumn Header="Montant"      Binding="{Binding Montant, StringFormat=C}" Width="110"/>
                    <DataGridTextColumn Header="Rapproché"    Binding="{Binding EstRapproche}"  Width="80"/>
                    <DataGridTemplateColumn Header="Action" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✔ Rapprocher" Style="{StaticResource SuccessBtn}"
                                        Height="22" FontSize="10"
                                        Command="{Binding DataContext.RapprocherCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
