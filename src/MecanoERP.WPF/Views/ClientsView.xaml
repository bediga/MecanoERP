<UserControl x:Class="MecanoERP.WPF.Views.ClientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ── Panneau liste ── -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titre -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                <StackPanel Orientation="Horizontal">
                    <Border Width="4" Height="22" Background="#0070F2" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="Clients" Style="{StaticResource PageTitle}"/>
                </StackPanel>
            </Border>

            <!-- Barre d'outils -->
            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding Recherche, UpdateSourceTrigger=PropertyChanged}"
                             Height="28" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="🔍 Chercher" Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Margin="6,0,0,0" Height="28"/>
                    <Button Grid.Column="3" Content="➕ Nouveau client"
                            Command="{Binding NouveauClientCommand}"
                            Style="{StaticResource PrimaryBtn}" Height="28" Margin="0,0,6,0"/>
                    <Button Grid.Column="4" Content="🔄 Actualiser"
                            Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Height="28"/>
                </Grid>
            </Border>

            <!-- DataGrid -->
            <DataGrid Grid.Row="2" Margin="14,10,14,0"
                      ItemsSource="{Binding Clients}"
                      SelectedItem="{Binding Selection}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nom"        Binding="{Binding Nom}"        Width="160"/>
                    <DataGridTextColumn Header="Prénom"     Binding="{Binding Prenom}"     Width="130"/>
                    <DataGridTextColumn Header="Téléphone"  Binding="{Binding Telephone}"  Width="130"/>
                    <DataGridTextColumn Header="Email"      Binding="{Binding Email}"      Width="200"/>
                    <DataGridTextColumn Header="Ville"      Binding="{Binding Ville}"      Width="130"/>
                    <DataGridTemplateColumn Header="Actions" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏ Modifier" Style="{StaticResource ToolBarBtn}"
                                            Margin="0,0,4,0" Height="22" FontSize="11"
                                            Command="{Binding DataContext.ModifierClientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="🗑 Supprimer" Style="{StaticResource DangerBtn}"
                                            Height="22" FontSize="11"
                                            Command="{Binding DataContext.SupprimerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="3"
                         Foreground="#0070F2" Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- ── Formulaire latéral ── -->
        <Border Grid.Column="1" Width="300" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="1,0,0,0"
                Visibility="{Binding AfficherFormulaire, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Header formulaire -->
                <Border Grid.Row="0" Background="#0070F2" Padding="16,12">
                    <TextBlock Text="Fiche Client" Foreground="White"
                               FontFamily="Segoe UI Semibold" FontSize="14"/>
                </Border>
                <!-- Champs -->
                <ScrollViewer Grid.Row="1">
                    <StackPanel Margin="16,14,16,0">
                        <TextBlock Text="Nom *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                        <TextBlock Text="Prénom" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Prenom, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                        <TextBlock Text="Téléphone" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Telephone, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                        <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                        <TextBlock Text="Adresse" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Adresse, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                        <TextBlock Text="Ville" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Ville, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                    </StackPanel>
                </ScrollViewer>
                <!-- Boutons -->
                <Border Grid.Row="2" Padding="16,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="💾 Sauvegarder"
                                Command="{Binding SauvegarderCommand}"
                                Style="{StaticResource SuccessBtn}" Margin="0,0,6,0" Height="30"/>
                        <Button Grid.Column="1" Content="Annuler"
                                Command="{Binding AnnulerCommand}"
                                Style="{StaticResource SecondaryBtn}" Height="30"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
