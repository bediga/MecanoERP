<UserControl x:Class="MecanoERP.WPF.Views.FacturesFournisseursView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                <StackPanel Orientation="Horizontal">
                    <Border Width="4" Height="22" Background="#BB0000" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="Factures fournisseurs (AP)" Style="{StaticResource PageTitle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="➕ Nouvelle facture" Command="{Binding NouvelleFactureCommand}"
                            Style="{StaticResource PrimaryBtn}" Height="28" Margin="0,0,6,0"/>
                    <Button Content="🔄 Actualiser" Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Height="28" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding MessageStatut}" Foreground="#107E3E"
                               FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="2" Margin="14,10,14,0"
                      ItemsSource="{Binding Factures}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N° Interne"   Binding="{Binding Numero}"            Width="130"/>
                    <DataGridTextColumn Header="N° Fourn."    Binding="{Binding NumeroFournisseur}"  Width="120"/>
                    <DataGridTextColumn Header="Fournisseur"  Binding="{Binding Fournisseur.Nom}"    Width="160"/>
                    <DataGridTextColumn Header="Date"         Binding="{Binding DateFacture, StringFormat=dd/MM/yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Échéance"     Binding="{Binding DateEcheance, StringFormat=dd/MM/yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Total TTC"    Binding="{Binding MontantTTC, StringFormat=C}"  Width="110"/>
                    <DataGridTextColumn Header="Solde"        Binding="{Binding SoldeRestant, StringFormat=C}" Width="110"/>
                    <DataGridTextColumn Header="Statut"       Binding="{Binding Statut}"             Width="130"/>
                    <DataGridTemplateColumn Header="Actions" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="💳 Payer" Style="{StaticResource SuccessBtn}"
                                        Height="22" FontSize="11"
                                        Command="{Binding DataContext.OuvrirPaiementCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="3"
                         Foreground="#BB0000" Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- Panneau droite : formulaire OU paiement -->
        <Border Grid.Column="1" Width="300" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
            <Grid>
                <!-- Nouvelle facture -->
                <Border Visibility="{Binding AfficherFormulaire, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#BB0000" Padding="16,12">
                            <TextBlock Text="Facture fournisseur" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="14"/>
                        </Border>
                        <StackPanel Grid.Row="1" Margin="16,14,16,0">
                            <TextBlock Text="Fournisseur *" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding Fournisseurs}" SelectedValuePath="Id"
                                      SelectedValue="{Binding FournisseurId}" DisplayMemberPath="Nom"
                                      Height="28" Margin="0,0,0,10"/>
                            <TextBlock Text="N° facture fournisseur" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding NumeroFournisseur, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                            <TextBlock Text="Montant HT ($) *" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding MontantHT, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                            <TextBlock Text="Échéance" Style="{StaticResource FieldLabel}"/>
                            <DatePicker SelectedDate="{Binding DateEcheance}" Height="28" Margin="0,0,0,10"
                                        FontSize="13" FontFamily="Segoe UI"/>
                        </StackPanel>
                        <Border Grid.Row="2" Padding="16,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="💾 Enregistrer"
                                        Command="{Binding SauvegarderCommand}"
                                        Style="{StaticResource SuccessBtn}" Margin="0,0,6,0" Height="30"/>
                                <Button Grid.Column="1" Content="Annuler"
                                        Command="{Binding AnnulerCommand}"
                                        Style="{StaticResource SecondaryBtn}" Height="30"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Paiement fournisseur -->
                <Border Visibility="{Binding AfficherPaiement, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#107E3E" Padding="16,12">
                            <TextBlock Text="Paiement fournisseur" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="14"/>
                        </Border>
                        <StackPanel Grid.Row="1" Margin="16,14,16,0">
                            <Border Background="#FFF8F0" BorderBrush="#E9730C" BorderThickness="1" CornerRadius="3" Padding="10,8" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="{Binding Selection.Fournisseur.Nom}" FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,4,0,0">
                                        <Run Text="Solde : " FontWeight="SemiBold" Foreground="#BB0000"/>
                                        <Run Text="{Binding Selection.SoldeRestant, StringFormat=C}" Foreground="#BB0000"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Montant ($)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding MontantPaiement, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                            <TextBlock Text="Mode de paiement" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding ModesPaiement}" SelectedItem="{Binding ModePaiement}"
                                      Height="28" Margin="0,0,0,10"/>
                            <TextBlock Text="Référence" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding ReferencePaiement, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>
                        </StackPanel>
                        <Border Grid.Row="2" Padding="16,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="✔ Confirmer"
                                        Command="{Binding EnregistrerPaiementCommand}"
                                        Style="{StaticResource SuccessBtn}" Margin="0,0,6,0" Height="30"/>
                                <Button Grid.Column="1" Content="Annuler"
                                        Command="{Binding AnnulerPaiementCommand}"
                                        Style="{StaticResource SecondaryBtn}" Height="30"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
