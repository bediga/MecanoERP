<UserControl x:Class="MecanoERP.WPF.Views.JournauxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                <StackPanel Orientation="Horizontal">
                    <Border Width="4" Height="22" Background="#107E3E" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="Journaux comptables — Écritures" Style="{StaticResource PageTitle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="➕ Nouvelle écriture" Command="{Binding NouvelleEcritureCommand}"
                            Style="{StaticResource PrimaryBtn}" Height="28" Margin="0,0,6,0"/>
                    <Button Content="🔄 Actualiser" Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Height="28" Margin="0,0,8,0"/>
                    <TextBlock Text="Période :" VerticalAlignment="Center" FontSize="12" Margin="0,0,5,0"/>
                    <DatePicker SelectedDate="{Binding DateDebut}" Height="26" Width="110" Margin="0,0,4,0"
                                FontSize="12" FontFamily="Segoe UI"/>
                    <TextBlock Text="→" VerticalAlignment="Center" Margin="2,0,4,0"/>
                    <DatePicker SelectedDate="{Binding DateFin}" Height="26" Width="110" Margin="0,0,6,0"
                                FontSize="12" FontFamily="Segoe UI"/>
                    <Button Content="Filtrer" Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Height="26"/>
                </StackPanel>
            </Border>

            <!-- KPIs totaux -->
            <DataGrid Grid.Row="2" Margin="14,10,14,0"
                      ItemsSource="{Binding Journaux}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N°"          Binding="{Binding Numero}"                              Width="110"/>
                    <DataGridTextColumn Header="Date"        Binding="{Binding DateJournal, StringFormat=dd/MM/yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Type"        Binding="{Binding TypeJournal}"                          Width="120"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}"                          Width="*"/>
                    <DataGridTextColumn Header="Total débit"  Binding="{Binding TotalDebits, StringFormat=C}"          Width="120"/>
                    <DataGridTextColumn Header="Total crédit" Binding="{Binding TotalCredits, StringFormat=C}"         Width="120"/>
                    <DataGridTemplateColumn Header="Actions" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑" Style="{StaticResource DangerBtn}" Height="22" Width="26"
                                        Command="{Binding DataContext.SupprimerJournalCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="3"
                         Foreground="#107E3E" Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- Formulaire nouvelle écriture -->
        <Border Grid.Column="1" Width="320" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="1,0,0,0"
                Visibility="{Binding AfficherFormulaire, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#107E3E" Padding="16,12">
                    <TextBlock Text="Nouvelle écriture journal" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="14"/>
                </Border>
                <ScrollViewer Grid.Row="1">
                    <StackPanel Margin="16,14,16,0">
                        <TextBlock Text="Type de journal *" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding TypesJournal}" SelectedItem="{Binding TypeJournal}"
                                  Height="28" Margin="0,0,0,10"/>
                        <TextBlock Text="Date *" Style="{StaticResource FieldLabel}"/>
                        <DatePicker SelectedDate="{Binding DateEcriture}" Height="28" Margin="0,0,0,10"
                                    FontSize="13" FontFamily="Segoe UI"/>
                        <TextBlock Text="Description *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10"/>

                        <!-- Lignes débit/crédit -->
                        <Border Background="#F0F7FF" BorderBrush="#0070F2" BorderThickness="1" CornerRadius="3" Padding="10,8" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Ligne débit" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                <TextBlock Text="Compte GL" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding Comptes}" SelectedValuePath="Id"
                                          SelectedValue="{Binding CompteDebitId}" DisplayMemberPath="Nom"
                                          Height="26" Margin="0,0,0,6"/>
                                <TextBlock Text="Montant ($)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding MontantDebit, UpdateSourceTrigger=PropertyChanged}" Height="26"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F0FFF0" BorderBrush="#107E3E" BorderThickness="1" CornerRadius="3" Padding="10,8" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Ligne crédit" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                <TextBlock Text="Compte GL" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding Comptes}" SelectedValuePath="Id"
                                          SelectedValue="{Binding CompteCredit2Id}" DisplayMemberPath="Nom"
                                          Height="26" Margin="0,0,0,6"/>
                                <TextBlock Text="Montant ($)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding MontantCredit, UpdateSourceTrigger=PropertyChanged}" Height="26"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding MessageStatut}" Foreground="#107E3E" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
                <Border Grid.Row="2" Padding="16,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="💾 Enregistrer"
                                Command="{Binding SauvegarderJournalCommand}"
                                Style="{StaticResource SuccessBtn}" Margin="0,0,6,0" Height="30"/>
                        <Button Grid.Column="1" Content="Annuler"
                                Command="{Binding AnnulerCommand}"
                                Style="{StaticResource SecondaryBtn}" Height="30"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
