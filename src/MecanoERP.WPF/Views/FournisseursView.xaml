<UserControl x:Class="MecanoERP.WPF.Views.FournisseursView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LISTE ═══ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                <StackPanel Orientation="Horizontal">
                    <Border Width="4" Height="22" Background="#E9730C" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="Fournisseurs" Style="{StaticResource PageTitle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="➕ Nouveau fournisseur" Command="{Binding NouveauFournisseurCommand}"
                            Style="{StaticResource PrimaryBtn}" Height="28" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding Recherche, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" Height="26" Margin="0,0,4,0"
                             FontSize="12" FontFamily="Segoe UI" VerticalContentAlignment="Center"/>
                    <Button Content="🔍" Command="{Binding ChargerCommand}"
                            Style="{StaticResource ToolBarBtn}" Height="26" Width="30"/>
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="2" Margin="14,10,14,0" IsReadOnly="True"
                      AutoGenerateColumns="False" ItemsSource="{Binding Fournisseurs}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nom"           Binding="{Binding Nom}"             Width="160"/>
                    <DataGridTextColumn Header="Contact"       Binding="{Binding ContactNom}"      Width="130"/>
                    <DataGridTextColumn Header="Téléphone"     Binding="{Binding Telephone}"       Width="120"/>
                    <DataGridTextColumn Header="Email"         Binding="{Binding Email}"           Width="170"/>
                    <DataGridTextColumn Header="Ville"         Binding="{Binding Ville}"           Width="100"/>
                    <DataGridTextColumn Header="Délai paie."   Binding="{Binding DelaiPaiementJours, StringFormat='{}{0} j'}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Actif"     Binding="{Binding EstActif}"        Width="55"/>
                    <DataGridTemplateColumn Header="Actions"   Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏ Modifier" Style="{StaticResource ToolBarBtn}"
                                            Margin="0,0,4,0" Height="22" FontSize="11"
                                            Command="{Binding DataContext.ModifierFournisseurCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="🗑" Style="{StaticResource DangerBtn}"
                                            Height="22" FontSize="11" Width="28"
                                            Command="{Binding DataContext.SupprimerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="3"
                         Foreground="#E9730C" Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- ═══ FORMULAIRE ═══ -->
        <Border Grid.Column="1" Width="350" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="1,0,0,0"
                Visibility="{Binding AfficherFormulaire, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#E9730C" Padding="16,12">
                    <TextBlock Text="Fiche Fournisseur" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="14"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,12,16,0">

                        <!-- Section Identification -->
                        <Border Background="#FFF5EE" BorderBrush="#E9730C" BorderThickness="0,0,0,2" Margin="0,0,0,10" Padding="0,0,0,4">
                            <TextBlock Text="📋 Identification" FontFamily="Segoe UI Semibold" FontSize="12" Foreground="#E9730C"/>
                        </Border>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Code fourn. *" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding CodeFournisseur, UpdateSourceTrigger=PropertyChanged}"
                                         Height="28" FontFamily="Consolas" FontSize="12"
                                         ToolTip="Code unique, ex: FOUR-001"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Nom entreprise *" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Nom du contact" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding ContactNom, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Poste/Titre" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding ContactPoste, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Téléphone" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Telephone, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Mobile" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding TelephoneMobile, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,8"/>

                        <TextBlock Text="Site web" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding SiteWeb, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,12"/>

                        <!-- Section Adresse -->
                        <Border Background="#F0F2F5" BorderBrush="#0070F2" BorderThickness="0,0,0,2" Margin="0,0,0,10" Padding="0,0,0,4">
                            <TextBlock Text="📍 Adresse" FontFamily="Segoe UI Semibold" FontSize="12" Foreground="#0070F2"/>
                        </Border>

                        <TextBlock Text="Adresse" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Adresse, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="90"/><ColumnDefinition Width="8"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ville" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Ville, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Code postal" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding CodePostal, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Prov." Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding Provinces}" SelectedItem="{Binding Province}" Height="28"/>
                            </StackPanel>
                        </Grid>

                        <!-- Section Comptabilité -->
                        <Border Background="#F0FFF0" BorderBrush="#107E3E" BorderThickness="0,0,0,2" Margin="0,0,0,10" Padding="0,0,0,4">
                            <TextBlock Text="💰 Comptabilité fournisseur" FontFamily="Segoe UI Semibold" FontSize="12" Foreground="#107E3E"/>
                        </Border>

                        <TextBlock Text="Catégorie" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding Categorie}" Height="28" Margin="0,0,0,8"/>

                        <TextBlock Text="N° compte fournisseur" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding NumeroCompte, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="N° TPS/TVH" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding NumeroTPS, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="N° TVQ" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding NumeroTVQ, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Délai de paiement (jours)" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding DelaisPaiement}" SelectedItem="{Binding DelaiPaiementJours}" Height="28"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Devise" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding Devises}" SelectedItem="{Binding Devise}" Height="28"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Limite de crédit ($)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding LimiteCreditCAD, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                 Height="28" Margin="0,0,0,8"/>

                        <CheckBox Content="Fournisseur actif" IsChecked="{Binding EstActif}" Margin="0,0,0,10"/>

                        <TextBlock Text="Notes" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalContentAlignment="Top" Margin="0,0,0,12"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Padding="16,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="💾 Sauvegarder"
                                Command="{Binding SauvegarderCommand}"
                                Style="{StaticResource SuccessBtn}" Margin="0,0,6,0" Height="30"/>
                        <Button Grid.Column="1" Content="Annuler"
                                Command="{Binding AnnulerCommand}"
                                Style="{StaticResource SecondaryBtn}" Height="30"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
