<UserControl x:Class="MecanoERP.WPF.Views.BalanceVerificationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,10">
            <StackPanel Orientation="Horizontal">
                <Border Width="4" Height="22" Background="#107E3E" CornerRadius="2" Margin="0,0,10,0"/>
                <TextBlock Text="⚖ Balance de vérification" Style="{StaticResource PageTitle}"/>
            </StackPanel>
        </Border>

        <!-- Barre de filtres -->
        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="16,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Exercice :" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#555" FontSize="12"/>
                <TextBox Text="{Binding Exercice}" Width="80" Height="28" Margin="0,0,12,0"/>
                <TextBlock Text="Période :" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#555" FontSize="12"/>
                <ComboBox ItemsSource="{Binding Periodes}" SelectedItem="{Binding Periode}"
                          Width="80" Height="28" Margin="0,0,12,0">

                </ComboBox>
                <Button Content="🔍 Calculer" Command="{Binding ChargerCommand}"
                        Style="{StaticResource PrimaryBtn}" Height="28" Padding="14,0"/>
                <Border Margin="16,0,0,0" Padding="10,4" CornerRadius="3"
                        Visibility="{Binding EstEquilibre, Converter={StaticResource BoolToVisibility}}">
                    <Border.Background><SolidColorBrush Color="#107E3E" Opacity="0.15"/></Border.Background>
                    <TextBlock Text="✅ Balance équilibrée" Foreground="#107E3E" FontFamily="Segoe UI Semibold" FontSize="12"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Lignes}"
                  IsReadOnly="True" AutoGenerateColumns="False"
                  BorderThickness="0" GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F7F9FC" FontSize="12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="N° Compte"   Binding="{Binding Numero}"         Width="100"/>
                <DataGridTextColumn Header="Nom"         Binding="{Binding Nom}"            Width="*"/>
                <DataGridTextColumn Header="Type"        Binding="{Binding TypeCompte}"     Width="80"/>
                <DataGridTextColumn Header="Total Débit" Binding="{Binding TotalDebit, StringFormat='{}{0:N2}'}"     Width="120"/>
                <DataGridTextColumn Header="Total Crédit" Binding="{Binding TotalCredit, StringFormat='{}{0:N2}'}"   Width="120"/>
                <DataGridTextColumn Header="Solde Déb."  Binding="{Binding SoldeDebiteur, StringFormat='{}{0:N2}'}"  Width="120"/>
                <DataGridTextColumn Header="Solde Cré."  Binding="{Binding SoldeCrediteur, StringFormat='{}{0:N2}'}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Totaux -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="16,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Border Background="#EFF6FF" Padding="10,4" CornerRadius="3" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total Débit : " FontSize="12"/>
                        <TextBlock Text="{Binding TotalDebit, StringFormat='{}{0:N2} $'}"
                                   FontFamily="Segoe UI Semibold" Foreground="#0070F2" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Background="#F0FFF4" Padding="10,4" CornerRadius="3">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total Crédit : " FontSize="12"/>
                        <TextBlock Text="{Binding TotalCredit, StringFormat='{}{0:N2} $'}"
                                   FontFamily="Segoe UI Semibold" Foreground="#107E3E" FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
