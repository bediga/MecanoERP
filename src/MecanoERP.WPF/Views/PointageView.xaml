<UserControl x:Class="MecanoERP.WPF.Views.PointageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panneau techniciens -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#0070F2" Padding="14,12">
                    <TextBlock Text="Techniciens" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="13"/>
                </Border>
                <Button Grid.Row="1" Content="🔄 Actualiser" Command="{Binding ChargerCommand}"
                        Style="{StaticResource ToolBarBtn}" Margin="8,8,8,4" Height="28"/>
                <ListBox Grid.Row="2" ItemsSource="{Binding Employes}" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,3">
                                <TextBlock FontWeight="SemiBold" FontSize="13">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} {1}">
                                            <Binding Path="Nom"/><Binding Path="Prenom"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="{Binding Poste}" Foreground="#555" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="8,4"/>
                            <EventSetter Event="Selected" Handler="Technicien_Selected"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!-- Panneau pointage -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                <StackPanel Orientation="Horizontal">
                    <Border Width="4" Height="22" Background="#E9730C" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="Pointage Atelier" Style="{StaticResource PageTitle}"/>
                </StackPanel>
            </Border>

            <!-- KPIs technicien sélectionné -->
            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,10">
                <StackPanel>
                    <!-- Statut pointage en cours -->
                    <Border Margin="0,0,0,10" Padding="10,8" CornerRadius="4"
                            Background="{Binding PointageOuvert, Converter={StaticResource NullToColorConverter}}"
                            BorderThickness="1" BorderBrush="#E0E0E0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                     Fill="{Binding PointageOuvert, Converter={StaticResource NullToBrushConverter}}"/>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Text>
                                    <Binding Path="PointageOuvert" Converter="{StaticResource PointageStatusConverter}" FallbackValue="● Aucun pointage en cours"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- KPIs jour -->
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#E3F2FD" BorderBrush="#0070F2" BorderThickness="1" CornerRadius="3" Padding="10,6" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Heures travaillées" FontSize="10" Foreground="#6E6E6E"/>
                                <TextBlock Text="{Binding HeuresTravaillees, StringFormat='{}{0:F1} h'}" FontWeight="Bold" FontSize="15" Foreground="#0070F2"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#E8F5E9" BorderBrush="#107E3E" BorderThickness="1" CornerRadius="3" Padding="10,6" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Heures facturables" FontSize="10" Foreground="#6E6E6E"/>
                                <TextBlock Text="{Binding HeuresFacturables, StringFormat='{}{0:F1} h'}" FontWeight="Bold" FontSize="15" Foreground="#107E3E"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FFF8E1" BorderBrush="#E9730C" BorderThickness="1" CornerRadius="3" Padding="10,6">
                            <StackPanel>
                                <TextBlock Text="Productivité" FontSize="10" Foreground="#6E6E6E"/>
                                <TextBlock Text="{Binding TauxProductivite, StringFormat='{}{0:F0} %'}" FontWeight="Bold" FontSize="15" Foreground="#E9730C"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Actions pointage -->
            <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,10">
                <StackPanel Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding OrdresEnCours}" SelectedValuePath="Id"
                              SelectedValue="{Binding OtId}" Width="160" Height="28" Margin="0,0,8,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Numero}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox ItemsSource="{Binding TypesPointage}" SelectedItem="{Binding TypePointage}"
                              Width="100" Height="28" Margin="0,0,8,0"/>
                    <Button Content="⏱ Pointer entrée" Command="{Binding PointerEntreeCommand}"
                            Style="{StaticResource SuccessBtn}" Height="28" Margin="0,0,6,0"/>
                    <Button Content="⏹ Pointer sortie" Command="{Binding PointerSortieCommand}"
                            Style="{StaticResource DangerBtn}" Height="28"/>
                    <TextBlock Text="{Binding MessageStatut}" FontSize="12" Foreground="#107E3E"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Pointages du jour -->
            <DataGrid Grid.Row="3" Margin="14,10,14,0"
                      ItemsSource="{Binding PointagesAujourdhui}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Technicien"  Binding="{Binding Employe.Nom}"                           Width="130"/>
                    <DataGridTextColumn Header="OT"          Binding="{Binding OrdreTravail.Numero}"                   Width="110"/>
                    <DataGridTextColumn Header="Début"       Binding="{Binding DateDebut, StringFormat=HH:mm}"         Width="70"/>
                    <DataGridTextColumn Header="Fin"         Binding="{Binding DateFin, StringFormat=HH:mm}"           Width="70"/>
                    <DataGridTextColumn Header="Durée (h)"   Binding="{Binding HeuresTravaillees, StringFormat=F2}"    Width="80"/>
                    <DataGridTextColumn Header="Type"        Binding="{Binding TypePointage}"                          Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
