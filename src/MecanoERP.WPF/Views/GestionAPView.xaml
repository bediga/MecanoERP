<UserControl x:Class="MecanoERP.WPF.Views.GestionAPView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,10">
            <StackPanel Orientation="Horizontal">
                <Border Width="4" Height="22" Background="#E9730C" CornerRadius="2" Margin="0,0,10,0"/>
                <TextBlock Text="🏢 Comptes Fournisseurs (AP)" Style="{StaticResource PageTitle}"/>
                <ProgressBar IsIndeterminate="True" Height="3" Width="60" Margin="16,0,0,0"
                             VerticalAlignment="Center" Foreground="#E9730C" Background="Transparent"
                             BorderThickness="0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </Border>

        <!-- KPIs -->
        <Grid Grid.Row="1" Margin="16,10,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="White" BorderBrush="#E9730C" BorderThickness="0,3,0,0" CornerRadius="4" Padding="14,10" Margin="0,0,8,8" Effect="{StaticResource ShadowSmall}">
                <StackPanel>
                    <TextBlock Text="Total AP" FontSize="11" Foreground="#888"/>
                    <TextBlock Text="{Binding TotalAP, StringFormat='{}{0:N0} $'}" FontSize="22" FontFamily="Segoe UI Semibold" Foreground="#E9730C" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="White" BorderBrush="#BB0000" BorderThickness="0,3,0,0" CornerRadius="4" Padding="14,10" Margin="0,0,8,8" Effect="{StaticResource ShadowSmall}">
                <StackPanel>
                    <TextBlock Text="À payer auj." FontSize="11" Foreground="#888"/>
                    <TextBlock Text="{Binding APayerAujourdhui, StringFormat='{}{0:N0} $'}" FontSize="22" FontFamily="Segoe UI Semibold" Foreground="#BB0000" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="White" BorderBrush="#E9730C" BorderThickness="0,3,0,0" CornerRadius="4" Padding="14,10" Margin="0,0,8,8" Effect="{StaticResource ShadowSmall}">
                <StackPanel>
                    <TextBlock Text="Cette semaine" FontSize="11" Foreground="#888"/>
                    <TextBlock Text="{Binding APayerSemaine, StringFormat='{}{0:N0} $'}" FontSize="22" FontFamily="Segoe UI Semibold" Foreground="#E9730C" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Background="White" BorderBrush="#BB0000" BorderThickness="0,3,0,0" CornerRadius="4" Padding="14,10" Margin="0,0,8,8" Effect="{StaticResource ShadowSmall}">
                <StackPanel>
                    <TextBlock Text="En souffrance" FontSize="11" Foreground="#888"/>
                    <TextBlock Text="{Binding EnSouffrance, StringFormat='{}{0:N0} $'}" FontSize="22" FontFamily="Segoe UI Semibold" Foreground="#BB0000" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Background="White" BorderBrush="#555" BorderThickness="0,3,0,0" CornerRadius="4" Padding="14,10" Margin="0,0,0,8" Effect="{StaticResource ShadowSmall}">
                <StackPanel>
                    <TextBlock Text="Factures en attente" FontSize="11" Foreground="#888"/>
                    <TextBlock Text="{Binding NombreEnAttente}" FontSize="22" FontFamily="Segoe UI Semibold" Foreground="#333" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Onglets -->
        <TabControl Grid.Row="2" Margin="16,8,16,16" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">

            <!-- ── Aging AP ── -->
            <TabItem Header="📊 Rapport d'âge AP">
                <DataGrid ItemsSource="{Binding LignesAging}" IsReadOnly="True" AutoGenerateColumns="False"
                          BorderThickness="0" GridLinesVisibility="Horizontal" AlternatingRowBackground="#F7F9FC" FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fournisseur"  Binding="{Binding FournisseurNom}" Width="*"/>
                        <DataGridTextColumn Header="Courant"      Binding="{Binding Courant,     StringFormat='{}{0:N2}'}" Width="110"/>
                        <DataGridTextColumn Header="1-30 j"       Binding="{Binding Jours0_30,   StringFormat='{}{0:N2}'}" Width="100"/>
                        <DataGridTextColumn Header="31-60 j"      Binding="{Binding Jours31_60,  StringFormat='{}{0:N2}'}" Width="100"/>
                        <DataGridTextColumn Header="61-90 j"      Binding="{Binding Jours61_90,  StringFormat='{}{0:N2}'}" Width="100"/>
                        <DataGridTextColumn Header="90+ j"        Binding="{Binding Plus90,      StringFormat='{}{0:N2}'}" Width="100"/>
                        <DataGridTextColumn Header="Total $"      Binding="{Binding Total,       StringFormat='{}{0:N2}'}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ── Paiements en lot ── -->
            <TabItem Header="💳 Paiements en lot">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Barre d'actions -->
                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="☑ Tout sélect."   Command="{Binding ToutSelectionnerCommand}"   Style="{StaticResource ToolBarBtn}" Margin="0,0,8,0"/>
                            <Button Content="☐ Tout désél."    Command="{Binding ToutDeselectionnerCommand}" Style="{StaticResource ToolBarBtn}" Margin="0,0,16,0"/>
                            <TextBlock Text="Mode :" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding ModesPaiement}" SelectedItem="{Binding ModePaiementLot}" Width="110" Height="28" Margin="0,0,12,0"/>
                            <Button Content="💳 Payer sélection" Command="{Binding PayerSelectionCommand}"
                                    Background="#107E3E" Foreground="White" BorderThickness="0"
                                    Height="28" Padding="14,0" Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                    <!-- Liste factures -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding FacturesSelectables}"
                              IsReadOnly="False" AutoGenerateColumns="False"
                              BorderThickness="0" GridLinesVisibility="Horizontal" FontSize="12">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="" Binding="{Binding EstSelectionnee, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Libelle}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- Message -->
                    <Border Grid.Row="2" Padding="12,8" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                        <TextBlock Text="{Binding Message}" FontSize="13" Foreground="#333"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ── Échéancier ── -->
            <TabItem Header="📅 Échéancier">
                <DataGrid ItemsSource="{Binding Echeancier}" IsReadOnly="True" AutoGenerateColumns="False"
                          BorderThickness="0" GridLinesVisibility="Horizontal" AlternatingRowBackground="#F7F9FC" FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Échéance"      Binding="{Binding DateEcheance,   StringFormat='dd/MM/yyyy'}" Width="100"/>
                        <DataGridTextColumn Header="Fournisseur"   Binding="{Binding FournisseurNom}" Width="*"/>
                        <DataGridTextColumn Header="N° Facture"    Binding="{Binding NumeroFacture}"  Width="130"/>
                        <DataGridTextColumn Header="Montant dû $"  Binding="{Binding MontantDu, StringFormat='{}{0:N2}'}" Width="120"/>
                        <DataGridTextColumn Header="J. restants"   Binding="{Binding JoursRestants}"  Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
