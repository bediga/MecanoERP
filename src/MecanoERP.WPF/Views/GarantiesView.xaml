<UserControl x:Class="MecanoERP.WPF.Views.GarantiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
            <StackPanel Orientation="Horizontal">
                <Border Width="4" Height="22" Background="#0070F2" CornerRadius="2" Margin="0,0,10,0"/>
                <TextBlock Text="Garanties" Style="{StaticResource PageTitle}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,8">
            <Button Content="🔄 Actualiser" Command="{Binding ChargerCommand}"
                    Style="{StaticResource ToolBarBtn}" Height="28"/>
        </Border>

        <DataGrid Grid.Row="2" Margin="14,10,14,0"
                  ItemsSource="{Binding Garanties}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Facture"     Binding="{Binding Facture.Numero}"       Width="140"/>
                <DataGridTextColumn Header="Client"      Binding="{Binding Facture.Client.Nom}"   Width="160"/>
                <DataGridTextColumn Header="Type"        Binding="{Binding Type}"                 Width="100"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}"          Width="200"/>
                <DataGridTextColumn Header="Début"       Binding="{Binding DateDebut, StringFormat=dd/MM/yyyy}" Width="100"/>
                <DataGridTextColumn Header="Fin"         Binding="{Binding DateFin, StringFormat=dd/MM/yyyy}"   Width="100"/>
                <DataGridTextColumn Header="Active"      Binding="{Binding EstActive}"            Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="3"
                     Foreground="#0070F2" Background="Transparent" BorderThickness="0"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
    </Grid>
</UserControl>
